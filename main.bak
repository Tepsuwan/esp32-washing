import machine
import time
import ujson
import ubinascii
import network
import struct
import ujson as json
import os
import requests
from umqtt.simple import MQTTClient
import esp32

# --- Configuration สำหรับบอร์ด WT32-ETH01 ---
RESET_PIN = 19 
WIFI_RESET_PIN = 14 
UPDATE_PIN = 13 

recovery_attempts = 0
MAX_RECOVERY_ATTEMPTS = 3

last_reset_time = 0
DEBOUNCE_TIME_MS = 500

# ประกาศใช้งาน Ethernet LAN แทน WiFi (สำหรับชิป LAN8720 บนบอร์ด WT32-ETH01)
lan = network.LAN(mdc=machine.Pin(23), mdio=machine.Pin(18), power=machine.Pin(16), phy_type=network.PHY_LAN8720, phy_addr=1)

def reset_handler(pin):
    global last_reset_time
    current_time = time.ticks_ms()
    if time.ticks_diff(current_time, last_reset_time) > DEBOUNCE_TIME_MS:
        last_reset_time = current_time
        print("Reset button (GPIO 19) pressed. Rebooting device...")
        time.sleep_ms(100)
        machine.reset()

def resetWIFI():
    # ฟังก์ชันเคลียร์ค่า config ตามต้นฉบับเดิม
    coder_version = {"version":5}
    try:
        with open('version.json', 'w') as f:
            f.write(json.dumps(coder_version))
        if check_file_exists('config.json'):
            print("Removing config.json")
            os.remove('config.json')
    except:
        pass

def get_temps():
    try: return esp32.mcu_temperature()
    except: return 'NA'

def get_temps2():
    try: return round((int(esp32.raw_temperature())-32)*0.5555555556,2)
    except: return 'NA'

def MyTemplate():
    # ส่งเวอร์ชันระบุว่าเป็นสายแลนเพื่อความชัดเจน
    return "5.0-WT32-LAN"

def check_file_exists(filename):
    try:
        os.stat(filename)
        return True
    except OSError:
        return False

def file_copy(source, dest):
    try:
        with open(source, 'rb') as f_source:
            with open(dest, 'wb') as f_dest:
                while True:
                    chunk = f_source.read(512)
                    if not chunk: break
                    f_dest.write(chunk)
        print(f"Successfully copied {source} to {dest}")
        return True
    except Exception as e:
        print(f"Error copying {source} to {dest}: {e}")
        try: os.remove(dest)
        except: pass
        return False

def backup_file(filename, backup_name):
    if check_file_exists(filename):
        print(f"Backing up {filename} to {backup_name}...")
        return file_copy(filename, backup_name)
    return False 

def restore_file(filename, backup_name):
    if check_file_exists(backup_name):
        print(f"Restoring {filename} from {backup_name}...")
        return file_copy(backup_name, filename)
    return False

def ensure_initial_backups():
    print("Checking for initial backups...")
    critical_files = ['main.py', 'wash.py', 'boot.py']
    for py_file in critical_files:
        bak_file = py_file.split('.')[0] + '.bak'
        if not check_file_exists(bak_file):
            if check_file_exists(py_file):
                file_copy(py_file, bak_file)
    print("Initial backup check complete.")

def get_device_real_mac():
    try:
        return ubinascii.hexlify(machine.unique_id()).decode('utf-8').upper()
    except:
        return "UNKNOWN_SERIAL"

# ฟังก์ชันดึง IP สำหรับ LAN Object (ดักจับเพื่อป้องกัน AttributeError แครช)
def get_ip_address():
    try:
        if lan.isconnected():
            return lan.ifconfig()[0]
    except:
        pass
    return "0.0.0.0"

# ฟังก์ชันเชื่อมต่อสายแลนและรอสัญญานเครือข่ายนิ่งสนิท
def connect_ethernet():
    print("Enabling Ethernet interface...")
    lan.active(True)
    attempt = 0
    while not lan.isconnected() and attempt < 20:
        print("Waiting for Ethernet IP Address via DHCP...")
        time.sleep(1)
        attempt += 1
        
    if lan.isconnected():
        print("Ethernet connected successfully!")
        try:
            print("Network config:", lan.ifconfig())
        except:
            print("Network config: Connected")
        print("Waiting 3 seconds for network stability...")
        time.sleep(3) # ป้องกันปัญหา ECONNABORTED สายหลุดตอนต่อ Socket แรกเริ่ม
        return True
    else:
        print("Ethernet connection timeout/failed.")
        return False

# โหลด Client ID จากไฟล์ config.json แบบไดนามิกตามที่เราได้ทำการตั้งค่าไว้
def load_client_id_from_config():
    real_mac = get_device_real_mac()
    filename = 'config.json'
    if check_file_exists(filename):
        try:
            with open(filename, 'r') as f:
                config_data = json.loads(f.read())
            configured_id = config_data.get('machine_id') or config_data.get('client_id')
            if configured_id:
                print(f"⚙️ Successfully loaded Client ID from config.json: {configured_id}")
                return str(configured_id)
        except Exception as e:
            print(f"⚠️ Error reading config.json: {e}")
    print(f"ℹ️ Configured ID not found. Using Real MAC: {real_mac}")
    return real_mac

# นำเข้าโมดูล wash ควบคุมเครื่องซักผ้าตามต้นฉบับเดิม
try:
    import wash
except ImportError:
    print("Error: 'wash.py' not found!")

# --- MQTT Setup ---
MQTT_BROKER = "141.98.19.212"
MQTT_PORT = 1883
CLIENT_ID = load_client_id_from_config()

STATUS_TOPIC = f"washing_machine/{CLIENT_ID}/status"
COMMAND_TOPIC = f"washing_machine/{CLIENT_ID}/commands"
command_response_topic = f"washing_machine/{CLIENT_ID}/command_response"

client = None

def recover_wash_py(error_obj):
    global recovery_attempts, client
    recovery_attempts += 1
    print(f"--- AUTO-RECOVERY INITIATED for wash.py (Attempt {recovery_attempts}) ---")
    try:
        if client:
            status_payload = {
                "version": 5.0, "app": "wash", "device_type": "wash",
                "ip": get_ip_address(), "client_id": CLIENT_ID,
                "status": "wash_py_crash", "online": False, "temp": MyTemplate(),
                "message": f"CRASH in wash.py: {error_obj}. Attempting auto-recovery {recovery_attempts}."
            }
            client.publish(command_response_topic.encode(), json.dumps(status_payload).encode())
    except: pass

    if not lan.isconnected():
        print("Auto-recovery failed: No network link. Rebooting...")
        time.sleep(5)
        machine.reset()
    
    file_copy('wash.py', 'wash.err') 
    if recovery_attempts > MAX_RECOVERY_ATTEMPTS:
        if restore_file('wash.py', 'wash.bak'):
            machine.reset()
        else:
            time.sleep(5)
            machine.reset()
    else:
        wash_url = 'http://141.98.19.212/ota/washing/wash'
        try:
            response = requests.get(wash_url)
            if response.status_code == 200:
                with open('wash.py', 'w') as f: f.write(response.text)
                time.sleep(3)
                machine.reset()
            else:
                response.close()
                time.sleep(5)
                machine.reset()
        except:
            time.sleep(5)
            machine.reset()

def perform_ota_update(source="MQTT"):
    global client
    print(f"Update triggered via {source}...")
    if not lan.isconnected(): return False 

    backup_file('boot.py', 'boot.bak')
    backup_file('main.py', 'main.bak')
    backup_file('wash.py', 'wash.bak')

    boot_url = 'http://141.98.19.212/ota/washing/boot'
    main_url = 'http://141.98.19.212/ota/washing/main'
    wash_url = 'http://141.98.19.212/ota/washing/wash'

    update_success = True
    files_updated = []
    
    def download_and_save(url, filename):
        nonlocal update_success, files_updated
        try:
            response = requests.get(url)
            if response.status_code == 200:
                with open(filename, 'w') as f: f.write(response.text)
                files_updated.append(filename)
            else: update_success = False
            response.close()
        except: update_success = False

    download_and_save(boot_url, 'boot.py')
    download_and_save(main_url, 'main.py')
    download_and_save(wash_url, 'wash.py')

    response_data = {"status": "success" if update_success else "partial_success", "version": 5.0, "message": f"Updated: {', '.join(files_updated)}. Rebooting..."}
    try: client.publish(command_response_topic.encode(), json.dumps(response_data).encode())
    except: pass
    time.sleep(5)
    machine.reset()

def sub_cb(topic, msg):
    try:
        data_json = json.loads(msg.decode())
        interpret_command(data_json)
    except Exception as e:
        print(f"Error in sub_cb: {e}")

def interpret_command(data_json):
    global client
    if 'command' in data_json:
        cmd = data_json['command']
        response_data = {}
        try:
            if cmd['key'] == 'update_code' and 'url' in cmd and 'file_name' in cmd:
                if cmd['file_name'] in ['main.py', 'wash.py', 'boot.py']:
                    backup_file(cmd['file_name'], cmd['file_name'].split('.')[0] + '.bak')
                res = requests.get(cmd['url'])
                if res.status_code == 200:
                    with open(cmd['file_name'], 'w') as f: f.write(res.text)
                    response_data = {"status": "success", "message": f"Updated {cmd['file_name']}. Rebooting..."}
                    client.publish(command_response_topic.encode(), json.dumps(response_data).encode())
                    time.sleep(5)
                    machine.reset()
            elif cmd['key'] == 'update_wash' and 'value' in cmd:
                backup_file('wash.py', 'wash.bak')
                res = requests.get(cmd['value'])
                if res.status_code == 200:
                    with open('wash.py', 'w') as f: f.write(res.text)
                    response_data = {"status": "success", "message": "Updated wash.py. Rebooting..."}
                    client.publish(command_response_topic.encode(), json.dumps(response_data).encode())
                    time.sleep(5)
                    machine.reset()
            elif cmd['key'] == 'update_main' and 'value' in cmd:
                backup_file('main.py', 'main.bak')
                res = requests.get(cmd['value'])
                if res.status_code == 200:
                    with open('main.py', 'w') as f: f.write(res.text)
                    response_data = {"status": "success", "message": "Updated main.py. Rebooting..."}
                    client.publish(command_response_topic.encode(), json.dumps(response_data).encode())
                    time.sleep(5)
                    machine.reset()
            elif cmd['key'] == 'update_version':
                perform_ota_update(source="MQTT")
            elif cmd['key'] == 'reset_error':
                txt = wash.reset_error()
                response_data = {"status": "success", "version": 5.0, "modbus_response": json.loads(txt)}
                client.publish(command_response_topic.encode(), json.dumps(response_data).encode())
                time.sleep(1)
                machine.reset()
            elif cmd['key'] == 'reset_wifi':
                resetWIFI()
                response_data = {"status": "success", "version": 5.0, "message": "Network reset completed."}
                client.publish(command_response_topic.encode(), json.dumps(response_data).encode())
                time.sleep(3)
                machine.reset()
            elif cmd['key'] == 'get_status':
                wash_status = json.loads(wash.get_machine_status())
                status_payload = {"version": 5.0, "cmd": "get_status", "ip": get_ip_address(), "client_id": CLIENT_ID, "status": wash_status}
                client.publish(STATUS_TOPIC.encode(), json.dumps(status_payload).encode())
            elif cmd['key'] == 'menu' and 'value' in cmd:
                txt = wash.select_program(int(cmd['value']))
                response_data = {"status": "success", "version": 5.0, "modbus_response": json.loads(txt)}
            elif cmd['key'] == 'coins' and 'value' in cmd:
                txt = wash.add_coins(int(cmd['value']))
                response_data = {"status": "success", "version": 5.0, "modbus_response": json.loads(txt)}
            elif cmd['key'] == 'start':
                txt = wash.start_operation()
                response_data = {"status": "success", "version": 5.0, "modbus_response": json.loads(txt)}
            elif cmd['key'] == 'stop':
                txt = wash.stop_operation()
                response_data = {"status": "success", "modbus_response": json.loads(txt)}
            elif cmd['key'] == 'command' and 'address' in cmd and 'value' in cmd:
                txt = wash.sendcommand(int(cmd['address']), cmd['value'])
                response_data = {"status": "success", "version": 5.0, "modbus_response": json.loads(txt)}
            elif cmd['key'] == 'register' and 'address' in cmd and 'value' in cmd:
                txt = wash.send_command(int(cmd['address']), cmd['value'])
                response_data = {"status": "success", "version": 5.0, "modbus_response": json.loads(txt)}
            elif cmd['key'] == 'reboot':
                machine.reset()
        except Exception as e:
            print(f"Error processing command: {e}")
        finally:
            try: client.publish(command_response_topic.encode(), json.dumps(response_data).encode())
            except: pass

def connect_and_subscribe():
    global client
    if client:
        try: client.disconnect()
        except: pass
    try:
        client = MQTTClient(CLIENT_ID, MQTT_BROKER, port=MQTT_PORT)
        client.set_callback(sub_cb)
        client.connect()
        client.subscribe(COMMAND_TOPIC.encode())
        print(f"Connected to MQTT broker {MQTT_BROKER} using Client ID: {CLIENT_ID}")
        return client
    except Exception as e:
        print(f"Failed to connect to MQTT broker: {e}")
        return None

# --- Boot Logic ---
ensure_initial_backups()
connect_ethernet()
client = connect_and_subscribe()

try:
    reset_button = machine.Pin(RESET_PIN, machine.Pin.IN, machine.Pin.PULL_UP)
    reset_button.irq(trigger=machine.Pin.IRQ_FALLING, handler=reset_handler)
except: pass

# --- ลูปหลักหลักการทำงาน (Main Loop) ---
while True:
    try:
        if not lan.isconnected():
            print("Ethernet Link Down. Reconnecting...")
            connect_ethernet()
            client = connect_and_subscribe()
            
        if client is not None:
            try:
                wash_status = json.loads(wash.get_machine_status())
            except Exception as ex:
                wash_status = {"status": "error", "message": f"Crash or missing: {ex}"}
                # สั่งรันกู้คืนอัตโนมัติหากฟังก์ชันใน wash.py พัง
                recover_wash_py(ex)
                
            status_payload = {
                "version": 5.0, "app": "washing", "device_type": "wash",
                "ip": get_ip_address(), "client_id": CLIENT_ID, "online": True,
                "temp": MyTemplate(), "status": wash_status,
                "real_mac": get_device_real_mac()
            }
            client.publish(STATUS_TOPIC.encode(), json.dumps(status_payload).encode())
            client.check_msg()
            recovery_attempts = 0
            
        time.sleep(5)
        
    except OSError as e_net:
        print(f"Network error: {e_net}. Retrying in 5 seconds...")
        time.sleep(5)
        client = connect_and_subscribe()
        if client is None:
            print("Cannot recover connection. Rebooting...")
            time.sleep(3)
            machine.reset()
    except Exception as e_main:
        print(f"Fatal error: {e_main}. Rebooting...")
        time.sleep(5)
        machine.reset()
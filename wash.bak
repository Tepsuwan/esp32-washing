import machine
import time
import ujson

# 🟢 ปรับเปลี่ยนตำแหน่งขาสำหรับบอร์ด WT32-ETH01 (ไม่ชนกับช่อง Thonny และสายแลน)
RS485_TX_PIN = 17  # ย้ายมาใช้ GPIO 17 (อยู่ฝั่งซ้ายของบอร์ด) ต่อเข้าขา DI ของโมดูล RS485
RS485_RX_PIN = 5   # ย้ายมาใช้ GPIO 5 (อยู่ฝั่งซ้ายของบอร์ด) ต่อเข้าขา RO ของโมดูล RS485

MODBUS_BAUDRATE = 9600
MODBUS_DATA_BITS = 8
MODBUS_STOP_BITS = 1
MODBUS_PARITY = None
MODBUS_SLAVE_ADDRESS = 1
MACHINE_TYPE = "wash"

def calculate_crc16(data):
    crc = 0xFFFF
    for byte in data:
        crc ^= byte
        for _ in range(8):
            if crc & 0x0001:
                crc >>= 1
                crc ^= 0xA001
            else:
                crc >>= 1
    return crc.to_bytes(2, 'little')

class ModbusRTUClient:
    # 🟢 เปลี่ยนมาใช้ Hardware UART ช่อง 2 (uart_id=2)
    def __init__(self, uart_id=2, tx_pin=RS485_TX_PIN, rx_pin=RS485_RX_PIN):
        self.uart = machine.UART(uart_id, baudrate=MODBUS_BAUDRATE, tx=tx_pin, rx=rx_pin, bits=MODBUS_DATA_BITS, stop=MODBUS_STOP_BITS, parity=MODBUS_PARITY)
        self.slave_address = MODBUS_SLAVE_ADDRESS
        time.sleep_ms(100)

    def _send_modbus_request(self, slave_address, function_code, register_address, quantity_or_value):
        request = bytearray([slave_address, function_code])
        request.extend(register_address.to_bytes(2, 'big'))
        request.extend(quantity_or_value.to_bytes(2, 'big'))
        crc = calculate_crc16(request)
        request.extend(crc)
        
        # ล้าง Buffer เก่าทิ้งก่อนส่ง
        while self.uart.any():
            self.uart.read()
            
        self.uart.write(request)
        time.sleep_ms(150) # เพิ่มเวลารอการตอบกลับเล็กน้อยให้ชิป LAN สลับการทำงานทัน
        
        if self.uart.any():
            response = self.uart.read()
            if len(response) >= 5:
                expected_crc = calculate_crc16(response[:-2])
                if response[-2:] == expected_crc:
                    return response
        return None

    def read_holding_registers(self, start_register, quantity):
        response = self._send_modbus_request(self.slave_address, 0x03, start_register, quantity)
        if response and response[1] == 0x03:
            byte_count = response[2]
            register_values = []
            for i in range(0, byte_count, 2):
                value = int.from_bytes(response[3+i:5+i], 'big')
                register_values.append(value)
            return register_values
        return None

    def write_single_register(self, register_address, value):
        response = self._send_modbus_request(self.slave_address, 0x06, register_address, value)
        if response and response[1] == 0x06:
            return True
        return False

    def write_multiple_registers(self, start_register, values):
        quantity = len(values)
        byte_count = quantity * 2
        request = bytearray([self.slave_address, 0x10])
        request.extend(start_register.to_bytes(2, 'big'))
        request.extend(quantity.to_bytes(2, 'big'))
        request.append(byte_count)
        for value in values:
            request.extend(value.to_bytes(2, 'big'))
        crc = calculate_crc16(request)
        request.extend(crc)
        
        while self.uart.any():
            self.uart.read()
            
        self.uart.write(request)
        time.sleep_ms(150)
        
        if self.uart.any():
            response = self.uart.read()
            if len(response) >= 8 and response[1] == 0x10:
                return True
        return False

modbus_client = ModbusRTUClient()

def get_machine_status():
    try:
        registers = modbus_client.read_holding_registers(20, 40)
        if registers:
            status_map = {0: "poweroff", 1: "standby", 2: "autorun", 3: "idle"}
            door_map = {0: "normal", 1: "open", 2: "close", 3: "lock"}
            
            machine_status = status_map.get(registers[0], "unknown")
            door_status = door_map.get(registers[1], "unknown")
            
            status_data = {
                "status": "success",
                "machine_type": MACHINE_TYPE,
                "machine_status": machine_status,
                "door_status": door_status,
                "remain_time_h": registers[2],
                "remain_time_m": registers[3],
                "remain_time_s": registers[4],
                "water_in_temp": registers[6],
                "water_out_temp": registers[7],
                "coin_amount": registers[10],
                "need_coin": registers[11],
                "error_code": registers[15],
                "raw_registers": registers
            }
            return ujson.dumps(status_data)
        else:
            return ujson.dumps({"status": "error", "message": "Failed to read Modbus data."})
    except Exception as e:
        return ujson.dumps({"status": "error", "message": str(e)})

def select_program(program_no):
    if modbus_client.write_single_register(5, program_no):
        return ujson.dumps({"status": "success", "message": f"Program {program_no} selected."})
    return ujson.dumps({"status": "error", "message": "Failed to select program."})

def start_operation():
    if modbus_client.write_single_register(1, 1):
        return ujson.dumps({"status": "success", "message": "Operation started."})
    return ujson.dumps({"status": "error", "message": "Failed to start operation."})

def stop_operation():
    if modbus_client.write_single_register(3, 1):
        return ujson.dumps({"status": "success", "message": "Operation stopped."})
    return ujson.dumps({"status": "error", "message": "Failed to stop operation."})

def add_coins(amount):
    if modbus_client.write_single_register(4, amount):
        return ujson.dumps({"status": "success", "message": f"Added {amount} coins."})
    return ujson.dumps({"status": "error", "message": "Failed to add coins."})

def reset_error():
    if modbus_client.write_single_register(0, 1):
        return ujson.dumps({"status": "success", "message": "Error reset command sent."})
    return ujson.dumps({"status": "error", "message": "Failed to send error reset command."})